{
  "name": "insulhub-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prod-smoke:sales-report": "node scripts/prod-smoke-sales-report.cjs",
    "test:cloudflare": "vitest run --config cloudflare/vitest.config.mjs",
    "cloudflare:check": "wrangler deploy --dry-run --config cloudflare/wrangler.jsonc",
    "test:communications": "node scripts/test-communication-settings.cjs && node scripts/test-communication-delivery.cjs && node scripts/test-communication-merge-fields.cjs",
    "test": "npm run test:communications && npm run test:cloudflare"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@neondatabase/serverless": "^1.1.0",
    "date-fns": "^4.1.0",
    "next": "16.1.6",
    "pdf-lib": "^1.17.1",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@playwright/test": "^1.57.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10",
    "wrangler": "^4.111.0"
  }
}
